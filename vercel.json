{
  "functions": {
    "app/api/sync/route.ts": {
      "maxDuration": 60
    },
    "app/api/sync-votes/route.ts": {
      "maxDuration": 60
    },
    "app/api/sync-race-ratings/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/primaries/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/sync-votes",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/sync-race-ratings",
      "schedule": "0 11 * * 3"
    },
    {
      "path": "/api/cron/primaries",
      "schedule": "0 12 * * *"
    }
  ]
}
